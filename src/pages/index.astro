---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { readingTime, postHref, byDateDesc } from '../utils';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(byDateDesc);
const featured = posts[0];
---
<BaseLayout title="Threat Unpacked">
  <section class="hero">
    <div class="wrap-wide hero-inner">
      <p class="eyebrow">Operational Malware Analysis</p>
      <h1 class="hero-title">Threat<span class="accent">Unpacked</span></h1>
      <p class="hero-sub">
        Deep dives into incidents, implants, and intrusion sets. Less
        <em>what the malware does</em>, more <em>why it matters when you're
        the one responding.</em>
      </p>
      <div class="hero-actions">
        <a href={postHref(featured)} class="btn">Latest write-up →</a>
        <a href="/about" class="btn ghost">About</a>
      </div>
    </div>
  </section>

  <section class="wrap-wide list-section">
    <div class="section-head">
      <h2 class="section-title">Writing</h2>
      <span class="count">{posts.length} posts</span>
    </div>
    <div class="list">
      {posts.map((p) => (
        <PostCard
          href={postHref(p)}
          title={p.data.title}
          description={p.data.description}
          pubDate={p.data.pubDate}
          heroImage={p.data.heroImage}
          series={p.data.series}
          seriesPart={p.data.seriesPart}
          readingTime={readingTime(p.body)}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background:
      radial-gradient(900px 380px at 78% -10%, var(--accent-tint), transparent 60%),
      var(--night);
    color: var(--night-ink);
    border-bottom: 1px solid var(--line);
  }
  .hero-inner { padding: clamp(3.5rem, 8vw, 6.5rem) 1.5rem clamp(3rem, 7vw, 5.5rem); max-width: 860px; }
  .hero .eyebrow { color: var(--accent-deep); filter: brightness(1.35); }
  .hero-title {
    font-size: clamp(2.1rem, 1.2rem + 5vw, 5rem);
    margin: 0.5rem 0 1rem; color: var(--night-ink); line-height: 1.02;
    overflow-wrap: anywhere;
  }
  .hero-title .accent { color: var(--accent); }
  .hero-sub {
    font-size: clamp(1.05rem, 1rem + 0.4vw, 1.3rem);
    color: var(--night-muted); max-width: 52ch; line-height: 1.6; margin: 0 0 2rem;
  }
  .hero-sub em { color: var(--night-ink); font-style: italic; }
  .hero-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .btn {
    display: inline-block; font-family: var(--font-mono); font-size: 0.85rem; font-weight: 500;
    padding: 0.7rem 1.2rem; border-radius: 8px; background: var(--accent); color: #fff;
    border: 1px solid var(--accent); transition: transform .12s, background .15s;
  }
  .btn:hover { background: var(--accent-deep); text-decoration: none; transform: translateY(-1px); }
  .btn.ghost { background: transparent; color: var(--night-ink); border-color: rgba(255,255,255,0.22); }
  .btn.ghost:hover { border-color: var(--accent); color: var(--accent); background: transparent; }

  .list-section { padding: 3.5rem 1.5rem 1rem; max-width: 820px; }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.5rem; }
  .section-title { margin: 0; font-size: 1.1rem; font-family: var(--font-mono); font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-soft); }
  .count { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
</style>
