---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { readingTime, postHref, byDateDesc, isoDate } from '../utils';
import type { CollectionEntry } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(byDateDesc);
const featured = posts[0];
const rest = posts.slice(1);

// A disassembler-style symbol name for a post, e.g. sub_safepay_lockbit3.
function symbol(post: CollectionEntry<'posts'>): string {
  if (post.data.seriesPart) return `sub_driver_analyzer_pt${post.data.seriesPart}`;
  const parts = post.slug.split('-').filter((w) => !['a','an','the','of','from','to','and','with','in','on'].includes(w));
  return 'sub_' + parts.slice(0, 3).join('_');
}

// Classify a post by the malware/topic it actually covers — from its own
// tags — and colour it. This labels the subject, it does not invent severity.
const CAT: Array<[RegExp, string, string]> = [
  [/ransom/i, 'ransomware', 'crit'],
  [/rootkit|kernel|driver|netfilter/i, 'rootkit', 'high'],
  [/\b(rat|asyncrat|backdoor|trojan|implant|botnet)\b/i, 'RAT', 'high'],
  [/loader|dropper|downloader|packer|nuitka|shellcode/i, 'loader', 'med'],
  [/c2|infrastructure|staging|tunnel|opendir|open.?dir/i, 'C2-infra', 'med'],
  [/apt|espionage|nation|ukraine|pakistan/i, 'APT', 'high'],
];
function classify(post: CollectionEntry<'posts'>): { label: string; sev: string } {
  const hay = (post.data.tags.join(' ') + ' ' + post.slug + ' ' + post.data.title).toLowerCase();
  for (const [re, label, sev] of CAT) if (re.test(hay)) return { label, sev };
  const t = post.data.tags[0];
  return { label: t ? t.replace(/\s+/g, '-') : 'writeup', sev: 'low' };
}

const xrefs = (post: CollectionEntry<'posts'>) =>
  post.data.tags.slice(0, 3).map((t) => t.replace(/\s+/g, '-'));

// ── SEGMENTS ─────────────────────────────────────────────────────
// Each post belongs to one track, rendered as its own disassembler
// segment. Assignment is derived from the post's own tags/series.
const GROUPS = [
  { id: 're',    seg: '.text',  label: 'reverse engineering', base: 0x00401000 },
  { id: 'cti',   seg: '.idata', label: 'threat intelligence', base: 0x10001000 },
  { id: 'tool',  seg: '.rdata', label: 'tooling & vuln research', base: 0x00418000 },
  { id: 'notes', seg: '.data',  label: 'field notes', base: 0x0041f000 },
] as const;
type GroupId = typeof GROUPS[number]['id'];

const RE_SIG = ['reverse engineering', 'malware analysis', 'byovd', 'dpapi', 'dll sideloading'];
const CTI_SIG = ['threat intel', 'infrastructure', 'open-director', 'opendir', 'staging',
  'kill-chain', 'lateral-movement', 'botnet', 'phishing', 'vishing', 'apt', 'spearphishing'];

function groupOf(post: CollectionEntry<'posts'>): GroupId {
  if (post.data.series) return 'tool';
  const tags = post.data.tags.map((t) => t.toLowerCase());
  if (tags.length === 0) return post.slug.includes('netfilter') ? 're' : 'notes';
  const hasRE = tags.some((t) => t.includes('reverse engineering'));
  let re = 0, cti = 0;
  for (const t of tags) {
    if (RE_SIG.some((s) => t.includes(s))) re++;
    if (CTI_SIG.some((s) => t.includes(s))) cti++;
  }
  if (re > 0 && re >= cti && hasRE) return 're';
  if (cti > 0) return 'cti';
  if (hasRE) return 're';
  return 'cti';
}

// Address for the listing gutter — namespaced to the post's segment.
function addr(gid: GroupId, k: number, off = 0): string {
  const g = GROUPS.find((x) => x.id === gid)!;
  return `${g.seg}:` + (g.base + k * 0x680 + off).toString(16).padStart(8, '0');
}

// Group every post (for the Functions panel) and every non-featured
// post (for the listing segments), preserving date order within each.
const grouped = GROUPS.map((g) => ({
  ...g,
  all: posts.filter((p) => groupOf(p) === g.id),
  listed: rest.filter((p) => groupOf(p) === g.id),
})).filter((g) => g.all.length > 0);

const featGid = groupOf(featured);
const featSym = symbol(featured);
const featCat = classify(featured);
---
<BaseLayout title="Threat Unpacked">
  <div class="wrap-wide app">

    <!-- Functions window, grouped by segment -->
    <aside class="fns" aria-label="Functions">
      <h3>Functions&nbsp;<span class="fcount">[{posts.length}]</span></h3>
      <div class="filter" aria-hidden="true">filter&hellip;</div>
      <nav class="fnlist" aria-label="All writeups">
        {grouped.map((g) => (
          <>
            <p class="fngroup"><span class="fseg">{g.seg}</span> {g.label} <span class="fn-n">{g.all.length}</span></p>
            {g.all.map((p) => {
              const c = classify(p);
              return (
                <a class="fnrow" href={postHref(p)}>
                  <span class={`sq ${c.sev}`} aria-hidden="true"></span>
                  <span class="nm">{symbol(p)}</span>
                  <span class="sz">{readingTime(p.body)}m</span>
                </a>
              );
            })}
          </>
        ))}
      </nav>
    </aside>

    <!-- Listing -->
    <main class="listing">
      <!-- Featured -->
      <section class="hero-post">
        <p class="kicker"><span class="hi">&#9656; latest</span> <span class="in">in {GROUPS.find((x) => x.id === featGid)?.label}</span></p>
        <a class="ftitle" href={postHref(featured)}>{featured.data.title}</a>
        <p class="desc desc2">{featured.data.description}</p>
        <p class="meta"><span class={`sq ${featCat.sev}`} aria-hidden="true"></span><span class="cat">{featCat.label}</span> &middot; {isoDate(featured.data.pubDate)} &middot; {readingTime(featured.body)} min</p>
      </section>

      {grouped.filter((g) => g.listed.length > 0).map((g) => (
        <section class="segment">
          <header class="seg-head" id={g.id}>
            <span class="seg-tag">{g.seg}</span>
            <h2 class="seg-name">{g.label}</h2>
            <span class="seg-n">{g.all.length} {g.all.length === 1 ? 'writeup' : 'writeups'}</span>
          </header>
          {g.listed.map((p) => {
            const c = classify(p);
            return (
              <article class="row">
                <span class={`sq ${c.sev}`} aria-hidden="true"></span>
                <div class="row-c">
                  <a class="ftitle sm" href={postHref(p)}>{p.data.title}</a>
                  <p class="desc desc1">{p.data.description}</p>
                  <p class="meta"><span class="cat">{c.label}</span> &middot; {isoDate(p.data.pubDate)} &middot; {readingTime(p.body)} min</p>
                </div>
              </article>
            );
          })}
        </section>
      ))}
    </main>
  </div>
</BaseLayout>

<style>
  .app {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 0;
    align-items: start;
    padding-top: 0.5rem;
  }

  /* Functions window */
  .fns {
    position: sticky; top: 92px;
    align-self: start;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
    overflow: hidden;
    max-height: calc(100vh - 110px);
    display: flex; flex-direction: column;
  }
  .fns h3 {
    margin: 0; padding: 0.7rem 0.9rem 0.6rem;
    font-family: var(--font-mono); font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted);
    border-bottom: 1px solid var(--line);
  }
  .fns h3 .fcount { color: var(--faint, var(--muted)); }
  .filter {
    margin: 0.6rem 0.7rem; padding: 0.35rem 0.55rem;
    font-family: var(--font-mono); font-size: 0.74rem; color: var(--muted);
    background: var(--bg); border: 1px solid var(--line); border-radius: 5px;
  }
  .filter::before { content: '\2315\00a0'; color: var(--muted); }
  .fnlist { overflow-y: auto; padding-bottom: 0.4rem; }
  .fnrow {
    display: grid; grid-template-columns: auto 1fr auto; align-items: center;
    gap: 0.4rem; padding: 0.32rem 0.9rem;
    font-family: var(--font-mono); font-size: 0.76rem;
    border-left: 2px solid transparent; color: var(--reg);
  }
  .fnrow:hover { background: var(--accent-dim); border-left-color: var(--accent); text-decoration: none; }
  .fnrow .nm { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .fnrow .sz { color: var(--muted); font-size: 0.7rem; }
  .fngroup {
    display: flex; align-items: baseline; gap: 0.4rem; margin: 0;
    padding: 0.7rem 0.9rem 0.35rem; font-size: 0.68rem; color: var(--cmt);
    border-top: 1px solid var(--line); white-space: nowrap;
  }
  .fnlist > .fngroup:first-child { border-top: none; }
  .fngroup .fseg { color: var(--num); }
  .fngroup .fn-n { margin-left: auto; color: var(--addr); }

  /* Listing */
  .listing { min-width: 0; padding: 0 0 1rem 1.6rem; }

  /* Featured */
  .hero-post {
    padding: 0.4rem 0 1.8rem; margin-bottom: 0.6rem;
    border-bottom: 1px solid var(--line);
  }
  .kicker { font-family: var(--font-mono); font-size: 0.75rem; margin: 0 0 0.7rem; }
  .kicker .hi { color: var(--accent); font-weight: 500; }
  .kicker .in { color: var(--muted); }

  /* Titles */
  a.ftitle {
    display: block; font-family: var(--font-mono);
    color: var(--title); font-weight: 700; letter-spacing: -0.015em;
    font-size: clamp(1.6rem, 1.1rem + 2.4vw, 2.4rem); line-height: 1.1;
    text-wrap: balance;
  }
  a.ftitle.sm {
    font-size: clamp(1.18rem, 1rem + 0.8vw, 1.42rem); font-weight: 600;
    line-height: 1.28; letter-spacing: -0.01em;
  }
  a.ftitle:hover { text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 5px; text-decoration-thickness: 2px; }

  /* Description + meta */
  .desc {
    color: var(--ink-soft); font-size: 0.98rem; line-height: 1.55;
    margin: 0.55rem 0 0; font-family: var(--font-sans);
    display: -webkit-box; -webkit-box-orient: vertical; overflow: hidden;
  }
  .row .desc { font-size: 0.92rem; margin-top: 0.4rem; }
  .desc1 { -webkit-line-clamp: 1; }
  .desc2 { -webkit-line-clamp: 2; }
  .meta {
    font-family: var(--font-mono); font-size: 0.75rem; color: var(--muted);
    margin: 0.6rem 0 0; display: flex; align-items: center; gap: 0.35rem;
  }
  .meta .cat { color: var(--str); }

  /* SEGMENT headers — the primary structure, made obvious */
  .segment { margin-top: 3rem; scroll-margin-top: 92px; }
  .seg-head {
    display: flex; align-items: center; gap: 0.7rem;
    margin: 0 0 1.4rem; padding-bottom: 0.7rem;
    border-bottom: 2px solid var(--accent-line);
  }
  .seg-tag {
    font-family: var(--font-mono); font-size: 0.78rem; color: var(--num);
    background: var(--accent-dim); border: 1px solid var(--line-strong);
    padding: 0.1rem 0.5rem; border-radius: 5px;
  }
  .seg-name {
    margin: 0; font-family: var(--font-sans);
    font-size: 1.15rem; font-weight: 700; letter-spacing: 0.02em;
    text-transform: capitalize; color: var(--title);
  }
  .seg-n { margin-left: auto; font-family: var(--font-mono); font-size: 0.74rem; color: var(--muted); }

  /* Rows */
  .row { display: flex; gap: 0.8rem; padding: 1.1rem 0; }
  .row + .row { border-top: 1px solid var(--line); }
  .row-c { min-width: 0; }

  .sq {
    display: inline-block; width: 0.55rem; height: 0.55rem; border-radius: 2px;
    flex: none; margin-top: 0.55rem;
  }
  .meta .sq { margin: 0; }
  .sq.crit { background: var(--crit); } .sq.high { background: var(--high); }
  .sq.med { background: var(--med); } .sq.low { background: var(--low); }
  .fnrow .sq { margin: 0; }

  @media (max-width: 860px) {
    .app { grid-template-columns: 1fr; }
    .fns { display: none; }
    .listing { padding-left: 0; }
  }
</style>
