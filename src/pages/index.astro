---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { readingTime, postHref, byDateDesc, fileName, thumbFor, isoDate } from '../utils';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(byDateDesc);
const featured = posts[0];
const rest = posts.slice(1);
const featImg = thumbFor(featured);

const stats = [
  { num: String(posts.length).padStart(2, '0'), lbl: 'entries' },
  { num: '02', lbl: 'public CVEs' },
  { num: '04', lbl: 'open tools' },
];
---
<BaseLayout title="Threat Unpacked">
  <section class="hero">
    <div class="scanlines" aria-hidden="true"></div>
    <div class="wrap-wide hero-inner">
      <p class="cmd boot" style="animation-delay:0ms"><span class="path">~/threat-unpacked</span> <span class="dollar">$</span> <span id="type-cmd" data-text="ls ./writing"></span><span class="type-caret" aria-hidden="true">▮</span></p>
      <p class="eyebrow boot" style="animation-delay:140ms">Operational Malware Analysis</p>
      <h1 class="hero-title boot" style="animation-delay:240ms"><span class="chev">&gt;_</span> Threat<span class="accent">Unpacked</span><span class="cursor" aria-hidden="true">▮</span></h1>
      <p class="hero-sub boot" style="animation-delay:380ms">
        Deep dives into incidents, implants, and intrusion sets. Less
        <em>what the malware does</em>, more <em>why it matters when you're
        the one responding.</em>
      </p>
      <div class="hero-actions boot" style="animation-delay:500ms">
        <a href={postHref(featured)} class="btn">$ cat latest →</a>
        <a href="/about" class="btn ghost">$ whoami</a>
      </div>
    </div>

    <div class="wrap-wide status-wrap">
      <div class="status boot" style="animation-delay:620ms">
        {stats.map((s) => (
          <div class="stat">
            <span class="num">{s.num}</span>
            <span class="lbl">// {s.lbl}</span>
          </div>
        ))}
        <div class="stat live">
          <span class="dot" aria-hidden="true"></span>
          <span class="lbl">status: writing</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured latest -->
  <section class="wrap-wide feat-section">
    <a class="featured reveal" href={postHref(featured)} aria-label={featured.data.title}>
      <div class="feat-media">
        {featImg
          ? <img src={featImg} alt="" />
          : <span class="feat-ph" aria-hidden="true">&gt;_</span>}
        <span class="feat-badge">// latest</span>
      </div>
      <div class="feat-body">
        <div class="feat-meta">
          <span class="date">[{isoDate(featured.data.pubDate)}]</span>
          <span class="prompt">$</span> <span class="file">{fileName(featured)}</span>
          {featured.data.series && <span class="tag">{featured.data.seriesPart ? `part ${featured.data.seriesPart}` : featured.data.series}</span>}
        </div>
        <h2 class="feat-title">{featured.data.title}</h2>
        <p class="feat-desc">{featured.data.description}</p>
        <div class="feat-foot">
          <span>{readingTime(featured.body)} min read</span>
          <span class="feat-read">$ read <span class="arrow" aria-hidden="true">▸</span></span>
        </div>
      </div>
    </a>
  </section>

  <!-- Archive -->
  <section class="wrap-wide list-section">
    <div class="section-head">
      <span class="section-title"># archive</span>
      <span class="count">{rest.length} more</span>
    </div>
    <div class="list">
      {rest.map((p) => (
        <PostCard
          href={postHref(p)}
          title={p.data.title}
          description={p.data.description}
          pubDate={p.data.pubDate}
          fileName={fileName(p)}
          image={thumbFor(p)}
          series={p.data.series}
          seriesPart={p.data.seriesPart}
          readingTime={readingTime(p.body)}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative; overflow: hidden;
    background:
      radial-gradient(820px 360px at 80% -20%, var(--accent-dim), transparent 60%),
      radial-gradient(620px 300px at 5% 120%, var(--accent2-dim), transparent 60%),
      var(--bg-soft);
    border-bottom: 1px solid var(--line-strong);
  }
  .scanlines { position: absolute; inset: 0; pointer-events: none; opacity: 0.5;
    background: repeating-linear-gradient(to bottom, rgba(255,255,255,0.018) 0 1px, transparent 1px 3px); }
  .hero-inner { position: relative; padding: clamp(3rem, 7vw, 5rem) 1.5rem clamp(1.6rem, 4vw, 2.4rem); max-width: 880px; }
  .cmd { font-family: var(--font-mono); font-size: 0.82rem; color: var(--muted); margin: 0 0 1.6rem; }
  .cmd .path { color: var(--ink-soft); }
  .cmd .dollar { color: var(--accent); }
  .type-caret { color: var(--accent); animation: blink 1.1s steps(1) infinite; }
  .type-caret.done { opacity: 0; }
  .hero .eyebrow { margin-bottom: 0.4rem; }
  .hero-title { font-family: var(--font-mono); font-size: clamp(2rem, 1.2rem + 4.4vw, 4.2rem);
    margin: 0.2rem 0 1.1rem; line-height: 1.05; letter-spacing: -0.02em; overflow-wrap: anywhere; }
  .hero-title .chev { color: var(--accent); font-size: 0.7em; margin-right: 0.3rem; text-shadow: var(--glow-soft); }
  .hero-title .accent { color: var(--accent); text-shadow: var(--glow); }
  .cursor { color: var(--accent); animation: blink 1.1s steps(1) infinite; margin-left: 0.1rem; }
  .hero-sub { font-size: clamp(1.02rem, 1rem + 0.4vw, 1.22rem); color: var(--ink-soft); max-width: 54ch; line-height: 1.65; margin: 0 0 1.9rem; }
  .hero-sub em { color: var(--ink); font-style: italic; }
  .hero-actions { display: flex; gap: 0.7rem; flex-wrap: wrap; }
  .btn { font-family: var(--font-mono); font-size: 0.82rem; font-weight: 500; padding: 0.6rem 1.05rem;
    border-radius: 6px; background: var(--accent); color: #0a0c10; border: 1px solid var(--accent); transition: box-shadow .15s, transform .12s; }
  .btn:hover { text-decoration: none; box-shadow: var(--glow); transform: translateY(-1px); }
  .btn.ghost { background: transparent; color: var(--accent); }
  .btn.ghost:hover { background: var(--accent-dim); box-shadow: var(--glow-soft); }

  /* ── Status strip ── */
  .status-wrap { position: relative; padding: 0 1.5rem clamp(2rem, 5vw, 3rem); max-width: 880px; }
  .status {
    display: flex; flex-wrap: wrap; gap: 0.6rem 2.2rem; align-items: center;
    padding: 0.9rem 1.2rem; border: 1px solid var(--line-strong); border-radius: var(--radius);
    background: color-mix(in srgb, var(--code-bg) 70%, transparent);
    font-family: var(--font-mono);
  }
  .stat { display: flex; align-items: baseline; gap: 0.5rem; }
  .stat .num { font-size: 1.4rem; font-weight: 700; color: var(--accent2); text-shadow: 0 0 10px var(--accent2-dim); }
  .stat .lbl { font-size: 0.76rem; color: var(--muted); }
  .stat.live { margin-left: auto; align-items: center; }
  .stat.live .lbl { color: var(--accent2); }
  .dot { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: var(--accent2);
    box-shadow: 0 0 0 0 var(--accent2); animation: pulse 2s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(78,201,168,.5); } 70% { box-shadow: 0 0 0 7px rgba(78,201,168,0); } 100% { box-shadow: 0 0 0 0 rgba(78,201,168,0); } }

  /* ── Featured ── */
  .feat-section { padding: 2.4rem 1.5rem 0; max-width: 980px; }
  .featured {
    display: grid; grid-template-columns: 1.05fr 1fr; gap: 0;
    border: 1px solid var(--line-strong); border-radius: 12px; overflow: hidden;
    background: var(--bg-soft); color: var(--ink); transition: border-color .2s, box-shadow .2s, transform .2s;
  }
  .featured:hover { border-color: var(--accent-line); box-shadow: var(--glow-soft), var(--shadow); transform: translateY(-2px); text-decoration: none; }
  .feat-media { position: relative; min-height: 260px; background: var(--code-bg); overflow: hidden; border-right: 1px solid var(--line); }
  .feat-media img { width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; transition: transform .4s; }
  .featured:hover .feat-media img { transform: scale(1.05); }
  .feat-ph { position: absolute; inset: 0; display: grid; place-items: center; font-family: var(--font-mono); font-size: 4rem; color: var(--accent); opacity: .4; text-shadow: var(--glow); }
  .feat-badge {
    position: absolute; top: 0.8rem; left: 0.8rem; z-index: 2;
    font-family: var(--font-mono); font-size: 0.7rem; color: #0a0c10; background: var(--accent);
    padding: 0.18rem 0.55rem; border-radius: 4px; font-weight: 600;
  }
  .feat-body { padding: 1.6rem 1.7rem; display: flex; flex-direction: column; }
  .feat-meta { font-family: var(--font-mono); font-size: 0.76rem; color: var(--muted); display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.7rem; }
  .feat-meta .date { color: var(--ink-soft); } .feat-meta .prompt, .feat-meta .file { color: var(--accent); }
  .feat-meta .tag { color: var(--accent2); background: var(--accent2-dim); padding: 0.05rem 0.45rem; border-radius: 4px; }
  .feat-title { font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem); line-height: 1.18; margin: 0 0 0.6rem; }
  .featured:hover .feat-title { color: var(--accent); }
  .feat-desc { color: var(--ink-soft); font-size: 0.96rem; line-height: 1.6; margin: 0 0 1.2rem;
    display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden; }
  .feat-foot { margin-top: auto; display: flex; align-items: center; justify-content: space-between;
    font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted); }
  .feat-read { color: var(--accent); }
  .feat-read .arrow { display: inline-block; transition: transform .15s; }
  .featured:hover .feat-read .arrow { transform: translateX(4px); }

  /* ── List ── */
  .list-section { padding: 2.8rem 1.5rem 1rem; max-width: 980px; }
  .section-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.2rem; }
  .section-title { font-family: var(--font-mono); font-size: 0.92rem; color: var(--ink-soft); }
  .count { font-family: var(--font-mono); font-size: 0.76rem; color: var(--muted); }
  .list { display: grid; gap: 0.9rem; }

  @media (max-width: 720px) {
    .featured { grid-template-columns: 1fr; }
    .feat-media { min-height: 180px; border-right: none; border-bottom: 1px solid var(--line); }
  }
</style>

<script>
  const el = document.getElementById('type-cmd');
  const caret = document.querySelector('.type-caret');
  if (el) {
    const text = el.dataset.text || '';
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) { el.textContent = text; }
    else {
      let i = 0;
      const tick = () => {
        el.textContent = text.slice(0, i++);
        if (i <= text.length) setTimeout(tick, 55);
        else setTimeout(() => caret?.classList.add('done'), 1400);
      };
      setTimeout(tick, 350);
    }
  }
</script>
