---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { readingTime, postHref, byDateDesc, isoDate } from '../utils';
import type { CollectionEntry } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(byDateDesc);
const featured = posts[0];
const rest = posts.slice(1);

// A disassembler-style symbol name for a post, e.g. sub_safepay_lockbit3.
function symbol(post: CollectionEntry<'posts'>): string {
  if (post.data.seriesPart) return `sub_driver_analyzer_pt${post.data.seriesPart}`;
  const parts = post.slug.split('-').filter((w) => !['a','an','the','of','from','to','and','with','in','on'].includes(w));
  return 'sub_' + parts.slice(0, 3).join('_');
}

// Classify a post by the malware/topic it actually covers — from its own
// tags — and colour it. This labels the subject, it does not invent severity.
const CAT: Array<[RegExp, string, string]> = [
  [/ransom/i, 'ransomware', 'crit'],
  [/rootkit|kernel|driver|netfilter/i, 'rootkit', 'high'],
  [/\b(rat|asyncrat|backdoor|trojan|implant|botnet)\b/i, 'RAT', 'high'],
  [/loader|dropper|downloader|packer|nuitka|shellcode/i, 'loader', 'med'],
  [/c2|infrastructure|staging|tunnel|opendir|open.?dir/i, 'C2-infra', 'med'],
  [/apt|espionage|nation|ukraine|pakistan/i, 'APT', 'high'],
];
function classify(post: CollectionEntry<'posts'>): { label: string; sev: string } {
  const hay = (post.data.tags.join(' ') + ' ' + post.slug + ' ' + post.data.title).toLowerCase();
  for (const [re, label, sev] of CAT) if (re.test(hay)) return { label, sev };
  const t = post.data.tags[0];
  return { label: t ? t.replace(/\s+/g, '-') : 'writeup', sev: 'low' };
}

// Deterministic, plausible address for the listing gutter.
const base = 0x401000;
function addr(i: number, off = 0): string {
  return '.text:' + (base + i * 0x680 + off).toString(16).padStart(8, '0');
}

const xrefs = (post: CollectionEntry<'posts'>) =>
  post.data.tags.slice(0, 4).map((t) => t.replace(/\s+/g, '-'));

const featSym = symbol(featured);
const featCat = classify(featured);
---
<BaseLayout title="Threat Unpacked">
  <div class="wrap-wide app">

    <!-- Functions window -->
    <aside class="fns" aria-label="Functions">
      <h3>Functions&nbsp;<span class="fcount">[{posts.length}]</span></h3>
      <div class="filter" aria-hidden="true">filter&hellip;</div>
      <nav class="fnlist" aria-label="All writeups">
        {posts.map((p, i) => {
          const c = classify(p);
          return (
            <a class="fnrow" href={postHref(p)}>
              <span class={`sq ${c.sev}`} aria-hidden="true"></span>
              <span class="nm">{symbol(p)}</span>
              <span class="sz">{readingTime(p.body)}m</span>
              <span class="ad">{addr(i)}</span>
            </a>
          );
        })}
      </nav>
    </aside>

    <!-- Listing -->
    <main class="listing">
      <p class="seg">; &#9552;&#9552;&#9552;&#9552;&#9552; SEGMENT: writing &#9552;&#9552;&#9552;&#9552;&#9552; {posts.length} functions &#9552;&#9552;&#9552;&#9552;&#9552;</p>

      <!-- Featured -->
      <section class="func latest">
        <p class="preamble"><span class="hi">; [ LATEST ]</span> <span class="cmt">auto-analysis flagged:</span> <span class="str">{featCat.label}</span></p>
        <div class="ln cur"><span class="a">{addr(0)}</span><span class="c"><span class="kw">public</span> <span class="reg">{featSym}</span></span></div>
        <div class="ln"><span class="a">{addr(0)}</span><span class="c tl"><span class="arrow">&#8658;</span><a class="ftitle" href={postHref(featured)}>{featured.data.title}</a></span></div>
        <div class="ln"><span class="a">{addr(0, 0x14)}</span><span class="c cmt">; {featured.data.description}</span></div>
        <div class="ln"><span class="a">{addr(0, 0x30)}</span><span class="c"><span class="kw">call</span> <span class="reg">read_writeup</span> &nbsp;<span class="cmt">; {isoDate(featured.data.pubDate)} &middot; {readingTime(featured.body)} min</span></span></div>
        {xrefs(featured).length > 0 && (
          <div class="ln"><span class="a">{addr(0, 0x30)}</span><span class="c cmt xref">; xrefs {xrefs(featured).map((t) => <span>&#8593; <a href={postHref(featured)}>{t}</a>&nbsp;&nbsp;</span>)}</span></div>
        )}
      </section>

      <p class="seg sub">; &#9472;&#9472;&#9472;&#9472;&#9472;&#9472;&#9472; archive &middot; {rest.length} functions &#9472;&#9472;&#9472;&#9472;&#9472;&#9472;&#9472;</p>

      {rest.map((p, idx) => {
        const i = idx + 1;
        const c = classify(p);
        const xs = xrefs(p);
        return (
          <section class="func">
            <div class="ln"><span class="a">{addr(i)}</span><span class="c cmt"><span class={`sq ${c.sev}`} aria-hidden="true"></span>{c.label} &nbsp; <span class="kw">public</span> <span class="reg">{symbol(p)}</span></span></div>
            <div class="ln"><span class="a">{addr(i)}</span><span class="c tl"><span class="arrow">&#8658;</span><a class="ftitle sm" href={postHref(p)}>{p.data.title}</a></span></div>
            <div class="ln"><span class="a">{addr(i, 0x1c)}</span><span class="c cmt">; {p.data.description}</span></div>
            <div class="ln"><span class="a">{addr(i, 0x34)}</span><span class="c cmt xref">; {isoDate(p.data.pubDate)} &middot; {readingTime(p.body)} min{xs.length ? ' · xref ' : ''}{xs.map((t) => <span>&#8593; <a href={postHref(p)}>{t}</a>&nbsp;&nbsp;</span>)}</span></div>
          </section>
        );
      })}

      <p class="seg sub">; &#9472;&#9472;&#9472; end of segment &middot; <a class="reg" href="/rss.xml">subscribe to the feed &#8595;</a> &#9472;&#9472;&#9472;</p>
    </main>
  </div>
</BaseLayout>

<style>
  .app {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 0;
    align-items: start;
    padding-top: 0.5rem;
  }

  /* Functions window */
  .fns {
    position: sticky; top: 92px;
    align-self: start;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--surface);
    overflow: hidden;
    max-height: calc(100vh - 110px);
    display: flex; flex-direction: column;
  }
  .fns h3 {
    margin: 0; padding: 0.7rem 0.9rem 0.6rem;
    font-family: var(--font-mono); font-size: 0.68rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted);
    border-bottom: 1px solid var(--line);
  }
  .fns h3 .fcount { color: var(--faint, var(--muted)); }
  .filter {
    margin: 0.6rem 0.7rem; padding: 0.35rem 0.55rem;
    font-family: var(--font-mono); font-size: 0.74rem; color: var(--muted);
    background: var(--bg); border: 1px solid var(--line); border-radius: 5px;
  }
  .filter::before { content: '\2315\00a0'; color: var(--muted); }
  .fnlist { overflow-y: auto; padding-bottom: 0.4rem; }
  .fnrow {
    display: grid; grid-template-columns: auto 1fr auto; align-items: center;
    gap: 0.4rem; padding: 0.32rem 0.9rem;
    font-family: var(--font-mono); font-size: 0.76rem;
    border-left: 2px solid transparent; color: var(--reg);
  }
  .fnrow:hover { background: var(--accent-dim); border-left-color: var(--accent); text-decoration: none; }
  .fnrow .nm { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .fnrow .sz { color: var(--muted); font-size: 0.7rem; }
  .fnrow .ad { grid-column: 2 / -1; color: var(--addr); font-size: 0.66rem; }

  /* Listing */
  .listing { min-width: 0; padding: 0 0 1rem 1.4rem; font-family: var(--font-mono); }
  .seg { color: var(--muted); opacity: 0.75; font-size: 0.76rem; white-space: nowrap; overflow: hidden; margin: 0 0 0.3rem; }
  .seg.sub { margin: 2rem 0 0.4rem; }
  .seg a { color: var(--reg); }

  .func { padding: 0.5rem 0.6rem 0.9rem; border-radius: 8px; }
  .func.latest {
    background: linear-gradient(180deg, var(--accent-dim), transparent 88%);
    box-shadow: inset 0 0 0 1px var(--line);
    padding: 0.9rem 0.8rem 1.1rem; margin-bottom: 0.4rem;
  }
  .preamble { margin: 0 0 0.35rem; font-size: 0.8rem; }
  .preamble .hi { color: var(--accent); }
  .preamble .cmt { color: var(--cmt); font-style: italic; }
  .preamble .str { color: var(--str); }

  .ln { display: grid; grid-template-columns: 116px 1fr; align-items: start; }
  .ln .a { color: var(--addr); user-select: none; font-size: 0.76rem; padding: 0.06rem 0.9rem 0.06rem 0; white-space: nowrap; }
  .ln .c { min-width: 0; font-size: 0.86rem; line-height: 1.5; }
  .ln.cur .c { background: var(--accent-dim); box-shadow: -0.5rem 0 0 var(--accent-dim); }
  .kw { color: var(--kw); } .reg { color: var(--reg); } .str { color: var(--str); }
  .cmt { color: var(--cmt); font-style: italic; }

  .tl { padding: 0.25rem 0 0.5rem; }
  .tl .arrow { color: var(--accent); margin-right: 0.5rem; }
  a.ftitle {
    color: var(--title); font-weight: 700; letter-spacing: -0.01em;
    font-size: clamp(1.5rem, 1rem + 2.4vw, 2.35rem); line-height: 1.12;
  }
  a.ftitle.sm { font-size: clamp(1.2rem, 1rem + 1vw, 1.5rem); font-weight: 600; }
  a.ftitle:hover { text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 5px; text-decoration-thickness: 2px; }
  .xref a { color: var(--reg); font-style: normal; }
  .xref a:hover { text-decoration: underline; text-underline-offset: 3px; }

  .sq { display: inline-block; width: 0.55rem; height: 0.55rem; border-radius: 2px; margin-right: 0.45rem; transform: translateY(1px); }
  .sq.crit { background: var(--crit); } .sq.high { background: var(--high); }
  .sq.med { background: var(--med); } .sq.low { background: var(--low); }
  .fnrow .sq { margin-right: 0; }

  @media (max-width: 860px) {
    .app { grid-template-columns: 1fr; }
    .fns { display: none; }
    .listing { padding-left: 0; }
    .ln { grid-template-columns: 84px 1fr; }
    .ln .a { font-size: 0.6rem; padding-right: 0.5rem; overflow: hidden; }
  }
</style>
