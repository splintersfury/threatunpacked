---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Not Found" description="Page not found.">
  <div class="wrap nf">
    <p class="eyebrow">404</p>
    <h1>Nothing unpacked here.</h1>
    <p class="muted">That path didn't resolve. The trail may have moved.</p>
    <a href="/" class="back">← Back to writing</a>
  </div>
</BaseLayout>
<style>
  .nf { padding: 6rem 1.5rem; text-align: center; }
  .nf h1 { margin: 0.5rem 0 0.8rem; }
  .back { display: inline-block; margin-top: 1.5rem; font-family: var(--font-mono); font-size: 0.85rem; }
</style>
