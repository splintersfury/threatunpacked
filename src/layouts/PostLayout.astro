---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { fileName, slugifyTag } from '../utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  readingTime: number;
}
const { post, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, series, seriesPart, tags } = post.data;
---
<BaseLayout title={title} description={description} image={heroImage} article={true}>
  <div class="read-progress" aria-hidden="true"><span id="read-bar"></span></div>
  <article class="post">
    <header class="post-head wrap">
      <p class="cmd"><span class="addr">.text</span> <span class="dollar">;</span> disassembly of <span class="file">{fileName(post)}</span></p>
      {series && <p class="eyebrow">{series}{seriesPart ? ` — part ${seriesPart}` : ''}</p>}
      <h1>{title}</h1>
      <div class="post-meta">
        <span class="mk">// </span><FormattedDate date={pubDate} />
        <span class="sep">·</span>
        <span>{readingTime} min read</span>
        {updatedDate && <><span class="sep">·</span><span>updated <FormattedDate date={updatedDate} /></span></>}
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((t) => <a href={`/tags/${slugifyTag(t)}/`} class="tag-link">#{t}</a>)}
        </div>
      )}
    </header>

    {heroImage && (
      <div class="hero-figure wrap-wide">
        <img src={heroImage} alt="" />
      </div>
    )}

    <div class="wrap prose">
      <slot />
    </div>

    <div class="wrap post-foot">
      <a href="/" class="back">&#8592; back to listing</a>
    </div>
  </article>
</BaseLayout>

<script type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
  const dark = document.documentElement.dataset.theme !== 'light';
  const mono = 'JetBrains Mono Variable, ui-monospace, monospace';
  mermaid.initialize({
    startOnLoad: false,
    securityLevel: 'loose',
    theme: 'base',
    themeVariables: dark ? {
      fontFamily: mono, fontSize: '13px',
      background: '#0b0e14',
      primaryColor: '#141922', primaryBorderColor: '#7dcfff', primaryTextColor: '#e8ebf0',
      lineColor: '#66748d', secondaryColor: '#171d27', tertiaryColor: '#0f1420',
      clusterBkg: '#0f1420', clusterBorder: '#242c37', edgeLabelBackground: '#0b0e14',
    } : {
      fontFamily: mono, fontSize: '13px',
      background: '#f5f6f4',
      primaryColor: '#ffffff', primaryBorderColor: '#0e6fb8', primaryTextColor: '#1c2430',
      lineColor: '#5c6675', secondaryColor: '#eef0ec', tertiaryColor: '#ffffff',
      clusterBkg: '#eef0ec', clusterBorder: '#d4d6cf', edgeLabelBackground: '#f5f6f4',
    },
  });
  // Shiki renders a ```mermaid fence as <pre data-language="mermaid"><code>...
  // — it does NOT add a language-mermaid class to the <code> element, so
  // match on the <pre>'s data-language instead.
  document.querySelectorAll('pre[data-language="mermaid"]').forEach((pre) => {
    const code = pre.querySelector('code');
    const div = document.createElement('div');
    div.className = 'mermaid not-prose';
    div.textContent = code?.textContent ?? '';
    pre.replaceWith(div);
  });
  mermaid.run();
</script>

<script>
  // Reading progress bar under the sticky header.
  const bar = document.getElementById('read-bar');
  if (bar) {
    const update = () => {
      const max = document.documentElement.scrollHeight - innerHeight;
      bar.style.width = max > 0 ? `${(scrollY / max) * 100}%` : '0';
    };
    addEventListener('scroll', update, { passive: true });
    update();
  }
</script>

<style>
  .read-progress {
    position: fixed; top: 77px; left: 0; right: 0; height: 2px; z-index: 49;
    background: transparent; pointer-events: none;
  }
  .read-progress span {
    display: block; height: 100%; width: 0;
    background: linear-gradient(90deg, var(--accent), var(--accent-soft));
    box-shadow: var(--glow-soft);
  }
  .post-head { padding: 3rem 0 1.5rem; }
  .cmd { font-family: var(--font-mono); font-size: 0.8rem; color: var(--muted); margin: 0 0 1.2rem; }
  .cmd .dollar { color: var(--cmt); }
  .cmd .addr { color: var(--addr); }
  .cmd .file { color: var(--reg); }
  .post-head h1 { margin: 0.3rem 0 0.9rem; }
  .post-meta {
    font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted);
    display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;
  }
  .post-meta .mk { color: var(--accent); opacity: 0.6; }
  .post-meta .sep { opacity: 0.5; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 0.9rem; }
  .tag-link {
    font-family: var(--font-mono); font-size: 0.74rem; color: var(--accent2);
    background: var(--accent2-dim); padding: 0.12rem 0.5rem; border-radius: 4px;
  }
  .tag-link:hover { text-decoration: underline; }
  .hero-figure { margin: 1.2rem auto 2.5rem; }
  .hero-figure img { width: 100%; max-height: 440px; object-fit: cover; border: 1px solid var(--line-strong); box-shadow: var(--shadow); }
  .prose { font-size: 1.05rem; }
  .prose :global(h2:first-child), .prose :global(h3:first-child) { margin-top: 0; }
  .post-foot { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px dashed var(--line-strong); }
  .back { font-family: var(--font-mono); font-size: 0.83rem; }
</style>
