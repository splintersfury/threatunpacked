---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
}
const { title, description, image, article } = Astro.props;
const fullTitle = title === 'Threat Unpacked' ? title : `${title} — Threat Unpacked`;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={fullTitle} description={description} image={image} article={article} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
