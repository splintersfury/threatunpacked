---
import { isoDate } from '../utils';
interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  fileName: string;
  series?: string;
  seriesPart?: number;
  readingTime?: number;
}
const { href, title, description, pubDate, fileName, series, seriesPart, readingTime } = Astro.props;
---
<article class="row reveal">
  <a href={href} class="row-link" aria-label={title}></a>
  <div class="ls">
    <span class="date">[{isoDate(pubDate)}]</span>
    <span class="prompt">$</span>
    <span class="file">{fileName}</span>
    <span class="leader" aria-hidden="true"></span>
    {readingTime && <span class="rt">{readingTime}m</span>}
    <span class="arrow" aria-hidden="true">▸</span>
  </div>
  <h2 class="title">{title}</h2>
  <p class="desc">{description}</p>
  {series && <span class="tag">{series}{seriesPart ? ` · part ${seriesPart}` : ''}</span>}
</article>

<style>
  .row {
    position: relative;
    padding: 1.35rem 1.1rem 1.4rem;
    border: 1px solid transparent;
    border-bottom: 1px solid var(--line);
    border-radius: var(--radius);
    transition: border-color .15s, background .15s;
  }
  .row:hover { background: var(--bg-soft); border-color: var(--line-strong); }
  .row-link { position: absolute; inset: 0; z-index: 1; }

  .ls {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted);
    margin-bottom: 0.55rem;
  }
  .date { color: var(--ink-soft); }
  .prompt { color: var(--accent); }
  .file { color: var(--accent); }
  .row:hover .file { text-shadow: var(--glow-soft); }
  .leader { flex: 1; border-bottom: 1px dotted var(--line-strong); transform: translateY(-3px); min-width: 1.5rem; }
  .rt { color: var(--muted); }
  .arrow { color: var(--muted); transition: transform .15s, color .15s; }
  .row:hover .arrow { color: var(--accent); transform: translateX(3px); }

  .title { font-size: 1.32rem; margin: 0 0 0.4rem; line-height: 1.25; transition: color .15s; }
  .row:hover .title { color: var(--accent); }
  .desc { margin: 0; color: var(--ink-soft); font-size: 0.94rem; line-height: 1.6; }
  .tag {
    display: inline-block; margin-top: 0.7rem;
    font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.04em;
    color: var(--accent); background: var(--accent-dim);
    padding: 0.15rem 0.5rem; border-radius: 4px;
  }
  @media (max-width: 560px) {
    .ls { flex-wrap: wrap; gap: 0.4rem; }
    .leader { display: none; }
  }
</style>
