---
import FormattedDate from './FormattedDate.astro';
interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  series?: string;
  seriesPart?: number;
  readingTime?: number;
}
const { href, title, description, pubDate, heroImage, series, seriesPart, readingTime } = Astro.props;
---
<article class:list={['card', { 'no-thumb': !heroImage }]}>
  <a href={href} class="card-link" aria-label={title}></a>
  {heroImage && (
    <div class="thumb"><img src={heroImage} alt="" loading="lazy" /></div>
  )}
  <div class="body">
    <div class="meta">
      <FormattedDate date={pubDate} />
      {series && <><span class="sep">·</span><span class="series">{series}{seriesPart ? ` · Part ${seriesPart}` : ''}</span></>}
      {readingTime && <><span class="sep">·</span><span>{readingTime} min read</span></>}
    </div>
    <h2 class="title">{title}</h2>
    <p class="desc">{description}</p>
    <span class="more">Read <span aria-hidden="true">→</span></span>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--line);
    align-items: start;
  }
  .card.no-thumb { grid-template-columns: 1fr; }
  .card:first-child { padding-top: 0.5rem; }
  .card-link { position: absolute; inset: 0; z-index: 1; }
  .thumb {
    aspect-ratio: 16 / 10; border-radius: var(--radius); overflow: hidden;
    border: 1px solid var(--line); background: var(--accent-tint);
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; border-radius: 0; transition: transform .4s ease; }
  .card:hover .thumb img { transform: scale(1.04); }
  .meta {
    font-family: var(--font-mono); font-size: 0.74rem; color: var(--muted);
    display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; margin-bottom: 0.5rem;
  }
  .sep { opacity: 0.5; }
  .series { color: var(--accent); }
  .title { font-size: 1.4rem; margin: 0 0 0.4rem; line-height: 1.2; transition: color .15s; }
  .card:hover .title { color: var(--accent); }
  .desc { margin: 0 0 0.7rem; color: var(--ink-soft); font-size: 0.96rem; line-height: 1.6; }
  .more { font-family: var(--font-mono); font-size: 0.78rem; color: var(--accent); font-weight: 500; }
  @media (max-width: 640px) {
    .card { grid-template-columns: 1fr; gap: 0.9rem; }
    .thumb { max-width: 100%; }
  }
</style>
