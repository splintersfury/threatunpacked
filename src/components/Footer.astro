---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="wrap-wide cols">
    <div class="col brand-col">
      <div class="f-brand"><span class="prompt">&gt;_</span> threat<span class="accent">_unpacked</span></div>
      <p class="f-tag">Deep dives into incidents, implants, and intrusion sets. Operational malware analysis, written to matter during a response.</p>
    </div>
    <div class="col">
      <h4>// site</h4>
      <a href="/">writing</a>
      <a href="/featured-investigations">investigations</a>
      <a href="/about">about</a>
      <a href="/rss.xml">rss</a>
    </div>
    <div class="col">
      <h4>// elsewhere</h4>
      <a href="https://github.com/splintersfury" rel="me">github</a>
      <a href="https://splintersfury.github.io/KernelSight/">kernelsight</a>
    </div>
  </div>
  <div class="wrap-wide bottom">
    <span class="prompt">$</span>
    <span>echo "© {year} threat unpacked · written by splintersfury"</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    background: var(--bg-soft);
    border-top: 1px solid var(--line-strong);
    padding: 3.2rem 0 2rem;
  }
  .cols { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2.5rem; }
  .f-brand { font-family: var(--font-mono); font-size: 1.05rem; font-weight: 600; color: var(--ink); }
  .f-brand .prompt, .f-brand .accent { color: var(--accent); }
  .f-tag { color: var(--muted); font-size: 0.9rem; max-width: 36ch; line-height: 1.65; margin-top: 0.7rem; }
  .col h4 { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.04em; color: var(--muted); margin: 0 0 0.8rem; font-weight: 500; }
  .col a { display: block; font-family: var(--font-mono); color: var(--ink-soft); font-size: 0.86rem; padding: 0.22rem 0; }
  .col a:hover { color: var(--accent); text-decoration: none; }
  .bottom {
    margin-top: 2.5rem; padding-top: 1.4rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono); color: var(--muted); font-size: 0.78rem;
    display: flex; gap: 0.5rem; align-items: center;
  }
  .bottom .prompt { color: var(--accent); }
  @media (max-width: 640px) { .cols { grid-template-columns: 1fr; gap: 2rem; } }
</style>
