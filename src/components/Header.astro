---
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
const links = [
  { href: '/', label: 'Writing' },
  { href: '/featured-investigations', label: 'Investigations' },
  { href: '/about', label: 'About' },
];
---
<header class="site-header">
  <div class="wrap-wide bar">
    <a href="/" class="brand" aria-label="Threat Unpacked home">
      <span class="brand-mark" aria-hidden="true">⌗</span>
      <span class="brand-text">Threat<span class="brand-accent">Unpacked</span></span>
    </a>

    <div class="actions">
      <nav id="nav" class="nav" aria-label="Primary">
        {links.map((l) => (
          <a href={l.href} class:list={['nav-link', { active: isActive(l.href) }]}>{l.label}</a>
        ))}
      </nav>

      <button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle dark mode">
        <svg class="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>

      <button id="menu-btn" class="icon-btn menu-btn" type="button" aria-label="Menu" aria-expanded="false" aria-controls="nav">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .bar { display: flex; align-items: center; justify-content: space-between; height: 64px; }
  .brand {
    display: inline-flex; align-items: baseline; gap: 0.5rem;
    font-family: var(--font-serif); font-size: 1.3rem; font-weight: 600;
    color: var(--ink); letter-spacing: -0.02em; white-space: nowrap;
  }
  .brand:hover { text-decoration: none; }
  .brand-mark { color: var(--accent); font-size: 1.18rem; transform: translateY(1px); }
  .brand-accent { color: var(--accent); }

  .actions { display: flex; align-items: center; gap: 0.4rem; }
  .nav { display: flex; align-items: center; gap: 0.3rem; }
  .nav-link {
    color: var(--ink-soft); font-size: 0.92rem; font-weight: 500;
    padding: 0.4rem 0.7rem; border-radius: 7px; white-space: nowrap;
  }
  .nav-link:hover { color: var(--ink); background: var(--accent-tint); text-decoration: none; }
  .nav-link.active { color: var(--accent); }

  .icon-btn {
    display: inline-grid; place-items: center; width: 36px; height: 36px;
    border: 1px solid var(--line-strong); background: var(--surface); color: var(--ink-soft);
    border-radius: 8px; cursor: pointer; transition: color .15s, border-color .15s;
  }
  .icon-btn:hover { color: var(--accent); border-color: var(--accent); }
  .icon-btn .moon { display: none; }
  :global(:root[data-theme='dark']) #theme-toggle .sun { display: none; }
  :global(:root[data-theme='dark']) #theme-toggle .moon { display: block; }
  .menu-btn { display: none; }

  @media (max-width: 640px) {
    .menu-btn { display: inline-grid; }
    .nav {
      position: absolute; top: 64px; right: 0; left: 0;
      flex-direction: column; align-items: stretch; gap: 0;
      background: var(--surface); border-bottom: 1px solid var(--line);
      padding: 0.5rem 1rem 1rem; box-shadow: var(--shadow);
      display: none;
    }
    .nav.open { display: flex; }
    .nav-link { padding: 0.7rem 0.5rem; font-size: 1rem; border-bottom: 1px solid var(--line); }
    .nav-link:last-child { border-bottom: none; }
  }
</style>

<script>
  const root = document.documentElement;
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });

  const menuBtn = document.getElementById('menu-btn');
  const nav = document.getElementById('nav');
  menuBtn?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(!!open));
  });
</script>
