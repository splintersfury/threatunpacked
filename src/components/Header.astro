---
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
const links = [
  { href: '/', label: 'writing' },
  { href: '/featured-investigations', label: 'investigations' },
  { href: '/about', label: 'about' },
];
---
<header class="site-header">
  <!-- window title bar -->
  <div class="titlebar">
    <div class="wrap-wide tb-inner">
      <a href="/" class="brand" aria-label="Threat Unpacked home">
        <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
        <span class="fname"><b>threat_unpacked</b>.i64 <span class="arch">[ x86-64 &middot; PE ]</span></span>
      </a>

      <div class="actions">
        <button class="term-trigger" type="button" data-term-open aria-label="Open command palette">
          <span class="tt-icon">&#8981;</span><span class="tt-label">jump to</span><span class="tt-key">g</span>
        </button>

        <button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle theme">
          <svg class="sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          <svg class="moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- tab strip (nav) -->
  <nav class="tabs" aria-label="Primary">
    <div class="wrap-wide tabs-inner">
      {links.map((l) => (
        <a href={l.href} class:list={['tab', { active: isActive(l.href) }]}>
          {l.href === '/' && <span class="view">IDA View &mdash; </span>}{l.label}
        </a>
      ))}
      <a href="/rss.xml" class="tab tab-end">strings.rss</a>
    </div>
  </nav>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 50; }

  .titlebar {
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    backdrop-filter: saturate(150%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .tb-inner { display: flex; align-items: center; justify-content: space-between; height: 42px; }
  .brand { display: inline-flex; align-items: center; gap: 0.7rem; white-space: nowrap; }
  .brand:hover { text-decoration: none; }
  .dots { display: inline-flex; gap: 0.45rem; }
  .dots i { width: 0.68rem; height: 0.68rem; border-radius: 50%; display: block; opacity: 0.9; }
  .dots i:nth-child(1) { background: #f7768e; }
  .dots i:nth-child(2) { background: #e0af68; }
  .dots i:nth-child(3) { background: #9ece6a; }
  .fname { font-family: var(--font-mono); font-size: 0.82rem; color: var(--muted); letter-spacing: -0.01em; }
  .fname b { color: var(--ink); font-weight: 600; }
  .fname .arch { color: var(--addr); }

  .actions { display: flex; align-items: center; gap: 0.4rem; }
  .term-trigger {
    display: inline-flex; align-items: center; gap: 0.42rem;
    font-family: var(--font-mono); font-size: 0.76rem; color: var(--ink-soft);
    background: var(--bg); border: 1px solid var(--line-strong);
    border-radius: 6px; padding: 0.28rem 0.55rem; cursor: pointer;
    transition: color .15s, border-color .15s;
  }
  .term-trigger:hover { color: var(--accent); border-color: var(--accent-line); }
  .term-trigger .tt-icon { color: var(--muted); }
  .term-trigger .tt-key {
    color: var(--muted); border: 1px solid var(--line-strong); border-radius: 3px;
    padding: 0 0.3rem; font-size: 0.72rem; line-height: 1.35;
  }
  .icon-btn {
    display: inline-grid; place-items: center; width: 32px; height: 30px;
    border: 1px solid var(--line-strong); background: var(--bg); color: var(--ink-soft);
    border-radius: 6px; cursor: pointer; transition: color .15s, border-color .15s;
  }
  .icon-btn:hover { color: var(--accent); border-color: var(--accent-line); }
  .sun { display: none; } .moon { display: block; }
  :global(:root[data-theme='light']) .sun { display: block; }
  :global(:root[data-theme='light']) .moon { display: none; }

  .tabs {
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    backdrop-filter: saturate(150%) blur(10px);
    border-bottom: 1px solid var(--line-strong);
  }
  .tabs-inner { display: flex; align-items: stretch; gap: 0; overflow-x: auto; scrollbar-width: none; }
  .tabs-inner::-webkit-scrollbar { display: none; }
  .tab {
    position: relative; top: 1px; white-space: nowrap;
    font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted);
    padding: 0.55rem 0.95rem; border: 1px solid transparent; border-bottom: none;
    transition: color .15s;
  }
  .tab .view { color: var(--addr); }
  .tab:hover { color: var(--ink); text-decoration: none; }
  .tab.active {
    color: var(--title); background: var(--bg);
    border-color: var(--line-strong); border-radius: 6px 6px 0 0;
  }
  .tab.active::after { content: ''; position: absolute; left: 0; right: 0; bottom: -1px; height: 2px; background: var(--accent); }
  .tab.active .view { color: var(--muted); }
  .tab-end { margin-left: auto; color: var(--addr); }

  @media (max-width: 560px) {
    .fname .arch { display: none; }
    .term-trigger .tt-label { display: none; }
    .tab .view { display: none; }
    .tab-end { margin-left: 0; }
  }
</style>

<script>
  const root = document.documentElement;
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = root.dataset.theme === 'light' ? 'dark' : 'light';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
